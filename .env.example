# Kopiere diese Datei zu ".env" und passe die Werte an.
SECRET_KEY=bitte-ein-langes-zufaelliges-secret-einsetzen

# Lokale Entwicklung (Standard, falls nicht gesetzt): SQLite
# DATABASE_URL=sqlite:///dev.db

# Produktion, Beispiel PostgreSQL:
# DATABASE_URL=postgresql://dj_user:dj_password@localhost:5432/dj_booking

# Produktion, Beispiel MySQL/MariaDB:
# DATABASE_URL=mysql+pymysql://dj_user:dj_password@localhost:3306/dj_booking
